---
import { personalInfo } from '@data/resume';
---

<section id="contact" class="relative py-28 px-6 overflow-hidden" style="background: #0a0a0a;">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="contact-orb-1 absolute top-1/4 left-1/4 w-96 h-96 rounded-full opacity-5" style="background: radial-gradient(circle, #06b6d4 0%, transparent 70%); animation: orbFloat1 8s ease-in-out infinite;"></div>
    <div class="contact-orb-2 absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full opacity-5" style="background: radial-gradient(circle, #06b6d4 0%, transparent 70%); animation: orbFloat2 10s ease-in-out infinite;"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto text-center">
    <div data-animate="section-title-contact" class="mb-16 opacity-0 -translate-x-8">
      <p class="font-mono text-accent text-xs tracking-[0.3em] uppercase mb-3">06 / Contact</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text mb-4">Get In Touch</h2>
      <div class="w-20 h-0.5 mx-auto" style="background: linear-gradient(to right, transparent, #06b6d4, transparent);"></div>
    </div>

    <p
      data-animate="contact-item"
      class="text-text-muted text-lg leading-relaxed mb-14 max-w-xl mx-auto opacity-0 translate-y-6"
    >
      I'm currently open to new opportunities. Whether you have a project in mind, a question, or just want to say hello — I'd love to hear from you.
    </p>

    <div class="flex flex-col gap-4 max-w-lg mx-auto">
      <a
        href={`mailto:${personalInfo.email}`}
        data-animate="contact-item"
        class="contact-row group flex items-center gap-5 p-5 rounded-xl border transition-all duration-300 opacity-0 translate-y-6"
        style="background: #141414; border-color: #262626;"
        onmouseover="this.style.borderColor='rgba(6,182,212,0.4)'; this.style.background='rgba(6,182,212,0.04)'; this.style.transform='translateX(6px)';"
        onmouseout="this.style.borderColor='#262626'; this.style.background='#141414'; this.style.transform='';"
      >
        <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 transition-all duration-300 text-accent font-mono text-sm font-bold" style="background: rgba(6,182,212,0.1); border: 1px solid rgba(6,182,212,0.2);">
          @
        </div>
        <div class="text-left">
          <p class="text-xs text-text-muted font-mono tracking-wider uppercase mb-1">Email</p>
          <p class="text-text group-hover:text-accent transition-colors font-medium">{personalInfo.email}</p>
        </div>
        <span class="ml-auto text-text-muted group-hover:text-accent transition-colors">→</span>
      </a>

      <a
        href={personalInfo.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        data-animate="contact-item"
        class="contact-row group flex items-center gap-5 p-5 rounded-xl border transition-all duration-300 opacity-0 translate-y-6"
        style="background: #141414; border-color: #262626;"
        onmouseover="this.style.borderColor='rgba(6,182,212,0.4)'; this.style.background='rgba(6,182,212,0.04)'; this.style.transform='translateX(6px)';"
        onmouseout="this.style.borderColor='#262626'; this.style.background='#141414'; this.style.transform='';"
      >
        <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 transition-all duration-300 text-accent font-mono text-sm font-bold" style="background: rgba(6,182,212,0.1); border: 1px solid rgba(6,182,212,0.2);">
          in
        </div>
        <div class="text-left">
          <p class="text-xs text-text-muted font-mono tracking-wider uppercase mb-1">LinkedIn</p>
          <p class="text-text group-hover:text-accent transition-colors font-medium">linkedin.com/in/tigran-petrosyants</p>
        </div>
        <span class="ml-auto text-text-muted group-hover:text-accent transition-colors">→</span>
      </a>

    </div>
  </div>
</section>

<style>
  @keyframes orbFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -20px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.95); }
  }
  @keyframes orbFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    40% { transform: translate(-25px, 30px) scale(1.08); }
    70% { transform: translate(20px, -15px) scale(0.92); }
  }
</style>
