---
import { personalInfo, summary, stats, languages } from '@data/resume';
---

<section id="about" class="py-28 px-6" style="background: transparent;">
  <div class="max-w-6xl mx-auto">
    <div data-animate="section-title-about" class="mb-16 opacity-0 -translate-x-8">
      <p class="font-mono text-accent text-xs tracking-[0.3em] uppercase mb-3">01 / About</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text mb-4">About Me</h2>
      <div class="w-20 h-0.5" style="background: linear-gradient(to right, #06b6d4, transparent);"></div>
    </div>

    <div class="grid lg:grid-cols-2 gap-16 items-start">
      <div data-animate="about-text" class="opacity-0 translate-y-8">
        <p class="text-text-muted leading-[1.9] text-base md:text-lg mb-8">
          {summary}
        </p>

        <div class="flex flex-col gap-3 text-sm font-mono">
          <div class="flex items-center gap-3">
            <span class="text-accent text-xs tracking-wider">LOCATION</span>
            <span class="h-px flex-1 opacity-20" style="background: #06b6d4;"></span>
            <span class="text-text-muted">{personalInfo.location}</span>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-accent text-xs tracking-wider">EMAIL</span>
            <span class="h-px flex-1 opacity-20" style="background: #06b6d4;"></span>
            <a href={`mailto:${personalInfo.email}`} class="text-text-muted hover:text-accent transition-colors">{personalInfo.email}</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-accent text-xs tracking-wider">STATUS</span>
            <span class="h-px flex-1 opacity-20" style="background: #06b6d4;"></span>
            <span class="text-accent flex items-center gap-2">
              <span class="w-2 h-2 rounded-full animate-pulse" style="background: #06b6d4;"></span>
              Open to opportunities
            </span>
          </div>
        </div>

        <div class="mt-10">
          <p class="font-mono text-accent text-xs tracking-[0.3em] uppercase mb-4">Languages</p>
          <div class="flex flex-wrap gap-2">
            {languages.map((lang) => (
              <span class="px-4 py-2 rounded-full text-sm font-mono text-text-muted border border-border hover:border-accent hover:text-accent transition-all duration-300" style="background: #141414;">
                {lang.language} <span class="text-accent opacity-60 mx-1">·</span> {lang.level}
              </span>
            ))}
          </div>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-4">
        {stats.map((stat) => (
          <div
            data-animate="stat-card"
            class="relative p-6 rounded-xl border text-center overflow-hidden opacity-0 translate-y-6 scale-90"
            style="background: #141414; border-color: #262626;"
            onmouseover="this.style.borderColor='rgba(6,182,212,0.4)'; this.style.boxShadow='0 0 30px rgba(6,182,212,0.08)';"
            onmouseout="this.style.borderColor='#262626'; this.style.boxShadow='';"
          >
            <div class="absolute inset-0 opacity-5" style="background: radial-gradient(ellipse at 50% 0%, #06b6d4 0%, transparent 70%);"></div>
            <div
              class="text-4xl md:text-5xl font-extrabold text-accent mb-2 relative z-10"
              data-count={stat.value}
            >
              {stat.value}
            </div>
            <div class="text-xs text-text-muted uppercase tracking-wider font-mono relative z-10">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
