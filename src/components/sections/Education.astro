---
import { education, certifications, languages } from '@data/resume';

const levelBars: Record<string, number> = {
  'Native': 5,
  'Professional': 4,
  'Conversational': 3,
  'Elementary': 1,
  'Basic': 2,
};
---

<section id="education" class="py-28 px-6" style="background: transparent;">
  <div class="max-w-6xl mx-auto">
    <div data-animate="section-title-education" class="mb-16 opacity-0 -translate-x-8">
      <p class="font-mono text-accent text-xs tracking-[0.3em] uppercase mb-3">05 / Education</p>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text mb-4">Education & Certifications</h2>
      <div class="w-20 h-0.5" style="background: linear-gradient(to right, #06b6d4, transparent);"></div>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <div>
        <p class="font-mono text-accent text-xs tracking-[0.3em] uppercase mb-6">Degrees</p>
        <div class="flex flex-col gap-5">
          {education.map((edu) => (
            <div
              data-animate="edu-card"
              class="group p-6 rounded-2xl border opacity-0 translate-y-6 transition-all duration-400"
              style="background: #141414; border-color: #262626;"
              onmouseover="this.style.borderColor='rgba(6,182,212,0.3)'; this.style.boxShadow='0 0 30px rgba(6,182,212,0.06)';"
              onmouseout="this.style.borderColor='#262626'; this.style.boxShadow='';"
            >
              <div class="flex items-start justify-between gap-4 mb-3">
                <h4 class="font-bold text-text group-hover:text-accent transition-colors duration-300">{edu.degree}</h4>
                <span class="font-mono text-xs text-accent shrink-0 mt-0.5">{edu.period.split(' — ')[0]}</span>
              </div>
              <p class="text-sm text-text-muted">{edu.institution}</p>
              <div class="mt-3 h-px opacity-20" style="background: linear-gradient(to right, #06b6d4, transparent); width: 40%;"></div>
            </div>
          ))}
        </div>

        <p class="font-mono text-accent text-xs tracking-[0.3em] uppercase mb-6 mt-10">Certifications</p>
        <div class="flex flex-col gap-5">
          {certifications.map((cert) => (
            <div
              data-animate="edu-card"
              class="group p-6 rounded-2xl border opacity-0 translate-y-6 transition-all duration-400"
              style="background: #141414; border-color: #262626;"
              onmouseover="this.style.borderColor='rgba(6,182,212,0.3)'; this.style.boxShadow='0 0 30px rgba(6,182,212,0.06)';"
              onmouseout="this.style.borderColor='#262626'; this.style.boxShadow='';"
            >
              <div class="flex items-start justify-between gap-4 mb-2">
                <h4 class="font-bold text-text group-hover:text-accent transition-colors duration-300">{cert.name}</h4>
                <span class="font-mono text-xs text-accent shrink-0 mt-0.5">{cert.period.split(' — ')[0]}</span>
              </div>
              <p class="text-sm text-text-muted">{cert.issuer}</p>
            </div>
          ))}
        </div>
      </div>

      <div>
        <p class="font-mono text-accent text-xs tracking-[0.3em] uppercase mb-6">Languages</p>
        <div class="flex flex-col gap-6">
          {languages.map((lang) => {
            const bars = levelBars[lang.level] || 3;
            return (
              <div
                data-animate="edu-card"
                class="opacity-0 translate-y-6"
              >
                <div class="flex items-center justify-between mb-3">
                  <span class="font-semibold text-text">{lang.language}</span>
                  <span class="font-mono text-xs text-accent">{lang.level}</span>
                </div>
                <div class="flex gap-1.5">
                  {[1,2,3,4,5].map((i) => (
                    <div
                      class="flex-1 h-1.5 rounded-full transition-all duration-300"
                      style={i <= bars ? 'background: #06b6d4;' : 'background: #262626;'}
                    ></div>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>
