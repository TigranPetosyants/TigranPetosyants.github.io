---
import { projects } from '@data/resume';
---

<section id="projects" class="relative" style="background: transparent;">
  <div data-animate="section-title-projects" class="relative z-10 opacity-0 -translate-x-8 px-6 pt-12 pb-6 md:px-12 md:pt-16 md:pb-0">
    <p class="font-mono text-accent text-xs tracking-[0.3em] uppercase mb-3">04 / Projects</p>
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text mb-4">Projects</h2>
    <div class="w-20 h-0.5 mb-4" style="background: linear-gradient(to right, #06b6d4, transparent);"></div>
    <p class="text-text-muted text-sm italic">All professional work projects are under NDA. The examples below are personal projects.</p>
  </div>

  <div style="height: 900vh;" id="projects-scroll-spacer"></div>

  <div id="project-panels-container" class="fixed inset-0 z-[12] pointer-events-none" aria-hidden="true">
    <svg id="project-connectors" class="absolute inset-0 w-full h-full pointer-events-none">
      {projects.map((_, index) => (
        <line
          data-connector={index}
          stroke="#06b6d4"
          stroke-width="1"
          stroke-dasharray="6 4"
          opacity="0"
        />
      ))}
      {projects.map((_, index) => (
        <circle
          data-connector-dot={index}
          r="3"
          fill="none"
          stroke="#06b6d4"
          stroke-width="1.5"
          opacity="0"
        />
      ))}
    </svg>

    {projects.map((project, index) => {
      const isLeft = [0, 2].includes(index);
      const maxMobileTech = 5;
      const extraCount = project.tech.length > maxMobileTech ? project.tech.length - maxMobileTech : 0;
      return (
      <a
        href={project.link}
        target="_blank"
        rel="noopener noreferrer"
        data-project-panel={index}
        class:list={[
          "project-panel-link absolute opacity-0 no-underline block",
          isLeft ? "panel-right" : "panel-left"
        ]}
        style="pointer-events: none;"
      >
        <div class="project-panel-card rounded-2xl border p-4 md:p-5" style="background: rgba(10, 15, 25, 0.85); border-color: rgba(6,182,212,0.15); backdrop-filter: blur(12px);">
          {project.image && (
            <div class="project-image rounded-lg overflow-hidden border mb-3 md:mb-4" style="border-color: rgba(6,182,212,0.1);">
              <img
                src={project.image}
                alt={project.title}
                class="w-full h-full object-cover object-top"
                loading="lazy"
              />
            </div>
          )}

          <h3 class="font-bold text-base md:text-xl text-text mb-1 md:mb-2">{project.title}</h3>

          <p class="text-xs md:text-sm text-text-muted leading-relaxed mb-2.5 md:mb-4 line-clamp-2 md:line-clamp-none">
            {project.description}
          </p>

          <div class="hidden md:flex flex-wrap gap-1.5">
            {project.tech.map((t) => (
              <span
                class="px-2 py-0.5 rounded text-xs font-mono border"
                style="color: #06b6d4; background: rgba(6,182,212,0.05); border-color: rgba(6,182,212,0.2);"
              >
                {t}
              </span>
            ))}
          </div>

          <div class="flex md:hidden flex-wrap gap-1">
            {project.tech.slice(0, maxMobileTech).map((t) => (
              <span
                class="px-1.5 py-0.5 rounded text-[10px] font-mono border"
                style="color: #06b6d4; background: rgba(6,182,212,0.05); border-color: rgba(6,182,212,0.2);"
              >
                {t}
              </span>
            ))}
            {extraCount > 0 && (
              <span
                class="px-1.5 py-0.5 rounded text-[10px] font-mono"
                style="color: rgba(6,182,212,0.6);"
              >
                +{extraCount}
              </span>
            )}
          </div>
        </div>
      </a>
    )})}
  </div>
</section>

<style is:global>
  .project-image {
    max-height: 100px;
  }

  @media (min-width: 768px) {
    .project-image {
      max-height: 180px;
    }
  }

  .project-panel-card {
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .project-panel-link:hover .project-panel-card {
    border-color: rgba(6, 182, 212, 0.4) !important;
    box-shadow: 0 8px 40px rgba(6, 182, 212, 0.12), 0 0 0 1px rgba(6, 182, 212, 0.1);
    transform: translateY(-2px);
  }

  .project-panel-link:active .project-panel-card {
    transform: scale(0.98);
  }

  .panel-left,
  .panel-right {
    top: 50%;
    width: calc(100vw - 2rem);
    max-width: 20rem;
    left: 50%;
    transform: translateX(-50%) translateY(-50%);
  }

  @media (min-width: 768px) {
    .panel-left,
    .panel-right {
      width: 100%;
      max-width: 24rem;
      left: auto;
      transform: none;
    }

    .panel-left {
      left: 6vw;
      right: auto;
      top: 50%;
    }

    .panel-right {
      right: 6vw;
      left: auto;
      top: 50%;
    }
  }
</style>
