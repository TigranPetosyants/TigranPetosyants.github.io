---
import { projects } from '@data/resume';

const gradients = [
  'linear-gradient(135deg, #0d1a2e 0%, #0a1628 50%, #060d1a 100%)',
  'linear-gradient(135deg, #0d1a1a 0%, #0a1a18 50%, #061410 100%)',
  'linear-gradient(135deg, #1a0d2e 0%, #18082a 50%, #100614 100%)',
  'linear-gradient(135deg, #1a1a0d 0%, #1a1808 50%, #141006 100%)',
];
---

<section id="projects" class="relative overflow-hidden" style="background: #0a0a0a;">
  <div class="projects-pin-wrapper">
    <div class="relative min-h-[auto] md:h-screen flex flex-col md:justify-center">
      <div data-animate="section-title-projects" class="relative md:absolute top-0 md:top-12 left-0 md:left-12 z-10 opacity-0 -translate-x-8 px-6 md:px-0 pt-12 md:pt-0 pb-6 md:pb-0">
        <p class="font-mono text-accent text-xs tracking-[0.3em] uppercase mb-3">04 / Projects</p>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text mb-4">Projects</h2>
        <div class="w-20 h-0.5 mb-4" style="background: linear-gradient(to right, #06b6d4, transparent);"></div>
        <p class="text-text-muted text-sm italic">All professional work projects are under NDA. The examples below are personal projects.</p>
      </div>

      <div data-animate="projects-track" class="projects-track flex gap-8 pl-6 lg:pl-12 md:pt-40 pb-4 md:pb-0">
        {projects.map((project, index) => (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            data-animate="project-card"
            class="project-card group relative flex-shrink-0 w-[85vw] md:w-[50vw] lg:w-[35vw] flex flex-col rounded-2xl border overflow-hidden transition-all duration-400 cursor-pointer no-underline"
            style="background: #141414; border-color: #262626;"
            onmouseover="this.style.borderColor='rgba(6,182,212,0.4)'; this.style.boxShadow='0 20px 60px rgba(6,182,212,0.1)';"
            onmouseout="this.style.borderColor='#262626'; this.style.boxShadow=''; this.style.transform='';"
          >
            <div
              class="relative h-48 overflow-hidden"
              style={gradients[index % gradients.length]}
            >
              {project.image ? (
                <img
                  src={project.image}
                  alt={project.title}
                  class="w-full h-full object-cover object-top opacity-85 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <div class="text-accent opacity-30 group-hover:opacity-60 transition-opacity duration-500 text-6xl font-mono font-bold select-none">
                    {String(index + 1).padStart(2, '0')}
                  </div>
                </div>
              )}
              <div class="absolute bottom-0 left-0 right-0 h-px opacity-20" style="background: linear-gradient(to right, transparent, #06b6d4, transparent);"></div>
            </div>

            <div class="flex flex-col flex-1 p-6">
              <h3 class="font-bold text-text text-lg mb-3 group-hover:text-accent transition-colors duration-300">
                {project.title}
              </h3>
              <p class="text-sm text-text-muted leading-relaxed mb-5 flex-1">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-1.5 mt-auto">
                {project.tech.map((t) => (
                  <span class="px-2.5 py-1 rounded-md text-xs font-mono text-text-muted border" style="background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08);">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="flex md:hidden justify-center gap-2 pb-8 pt-2">
        {projects.map((_, index) => (
          <div
            class="project-dot w-2 h-2 rounded-full transition-all duration-300"
            style={`background: #06b6d4; opacity: ${index === 0 ? '1' : '0.3'};`}
          ></div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 767px) {
    .projects-track {
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .projects-track::-webkit-scrollbar {
      display: none;
    }
    .project-card {
      scroll-snap-align: start;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll('.project-card') as NodeListOf<HTMLElement>;

  cards.forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = ((y - centerY) / centerY) * -6;
      const rotateY = ((x - centerX) / centerX) * 6;
      card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)';
    });
  });
</script>
